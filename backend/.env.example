# ── Neurix CRM ──
# Application
APP_NAME=Neurix CRM
APP_VERSION=1.0.0
DEBUG=false
CORS_ORIGINS=https://crm.wbtech.dev

# ── Supabase ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Auth ──
SESSION_DURATION_DAYS=14
TWO_FACTOR_ENABLED=true

# ── Uazapi (WhatsApp Integration) ──
# Base URL pública do FastAPI (webhook: {PUBLIC_API_BASE_URL}/api/webhooks/uazapi?secret=...)
PUBLIC_API_BASE_URL=https://crm.wbtech.dev
UAZAPI_URL=https://neurix.uazapi.com
UAZAPI_ADMIN_TOKEN=
UAZAPI_INSTANCE_TOKEN=
UAZAPI_WEBHOOK_SECRET=

# ── SMTP ──
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
